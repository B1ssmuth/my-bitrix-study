# IDE и системные файлы
.idea/
.vscode/
.fleet/
.env
logs/
mysql/
*.log

# --- БИТРИКС (подход "Черный список") ---

# Игнорируем ядро и загрузки (самые тяжелые папки)
www/bitrix/
www/upload/

# Игнорируем вообще всё в www, чтобы не тащить стандартные папки (auth, shop, crm и т.д.)
www/*

# --- ИСКЛЮЧЕНИЯ (что НАМ НУЖНО в репозитории) ---

# Твоя папка для разработки (самое важное!)
!www/local/

# Системные файлы в корне сайта
!www/.htaccess
!www/urlrewrite.php
!www/.access.php
!www/index.php
!www/bitrixsetup.php

# Если ты все-таки хочешь видеть свои шаблоны внутри bitrix/ (старый стиль), 
# то раскомментируй строки ниже, но лучше работай в /local/
#!www/bitrix/templates/
#!www/bitrix/components/
